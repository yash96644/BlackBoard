{
  "name": "blackboard-app",
  "description": "Professional drawing and whiteboard app",
  "author": {
    "name": "Yash Kumar Gupta"
  },
  "private": true,
  "version": "1.0.0",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "preview": "vite preview",
    "electron:dev": "concurrently \"cross-env NODE_ENV=development vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build:mac": "vite build && electron-builder --mac",
    "electron:build:win": "vite build && electron-builder --win",
    "electron:rebuild:win": "vite build && electron-builder --win --publish never",
    "electron:build:all": "vite build && electron-builder --mac --win",
    "electron:build:mas": "vite build && electron-builder --mac mas",
    "generate:icons": "electron-icon-builder --input=assets/icon.png --output=assets/"
  },
  "build": {
    "appId": "com.blackboard.app",
    "productName": "Blackboard",
    "copyright": "Copyright © 2025",
    "asar": true,
    "compression": "maximum",
    "nodeGypRebuild": false,
    "buildDependenciesFromSource": false,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "!node_modules/**/*",
      "!src/**/*",
      "!public/**/*",
      "!*.md",
      "!*.log",
      "!.env*",
      "!.git/**/*",
      "!.github/**/*",
      "!assets/**/*",
      "!build/**/*",
      "!vitest.setup.js",
      "!eslint.config.js",
      "!postcss.config.js",
      "!tailwind.config.js",
      "!BlackboardApp.code-workspace"
    ],
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "mac": {
      "protocols": [
        {
          "name": "Blackboard",
          "schemes": [
            "blackboard"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "darkModeSupport": true,
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "mas": {
      "type": "distribution",
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "hardenedRuntime": false,
      "entitlements": "build/entitlements.mas.plist",
      "entitlementsInherit": "build/entitlements.mas.inherit.plist"
    },
    "win": {
      "protocols": [
        {
          "name": "Blackboard",
          "schemes": [
            "blackboard"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "verifyUpdateCodeSignature": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "Install Blackboard",
      "sign": false,
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": true
    },
    "appx": {
      "applicationId": "Blackboard",
      "backgroundColor": "#111827",
      "displayName": "Blackboard",
      "identityName": "Blackboard.App",
      "publisherDisplayName": "Blackboard"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@supabase/supabase-js": "^2.105.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "electron-icon-builder": "^2.0.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.16.0",
    "perfect-freehand": "^1.2.3",
    "postcss": "^8.5.14",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.12",
    "vitest": "^4.1.6",
    "wait-on": "^9.0.10",
    "zustand": "^5.0.13"
  }
}
